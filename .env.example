# 引擎环境变量样例（复制为 .env 使用；Docker 部署经 compose 的 environment 注入，无需此文件）

# 访问令牌：留空则引擎首次启动自动生成（打印指纹，完整令牌经 /api/connection-info 获取）
ENGINE_TOKEN=

# 监听地址：默认 127.0.0.1（仅本机，最小暴露面）。
# 需要局域网/公网访问（手机直连、Docker 部署）时设为 0.0.0.0
ENGINE_HOST=127.0.0.1

# 对外可达地址（公网 IP / 域名）：连接串、二维码、网页直开地址用它。
# 不设则取第一块非回环网卡——容器/NAT 后面会变成内网地址，外部扫码连不上
ENGINE_PUBLIC_HOST=

# HTTP/WS 端口（实时视角另占 8800-8853 端口池，防火墙需一并放行）
PORT=8723

# 数据目录（机器人配置/脚本/令牌/AI 配置）
MCBOT_DATA_DIR=./data

# 网页客户端构建产物目录：设了就在根路径直出网页客户端（手机浏览器零安装直连）
# MCBOT_UI_DIST=./ui-dist

# 启动时明文打印令牌（默认只打指纹；交互式终端会自动打明文方便复制）
# ENGINE_PRINT_TOKEN=1
