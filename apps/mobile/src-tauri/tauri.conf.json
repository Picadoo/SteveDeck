{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SteveDeck",
  "version": "0.1.0",
  "identifier": "com.stevedeck.mobile",
  "build": {
    "frontendDist": "../../../packages/ui/dist",
    "devUrl": "http://localhost:5273",
    "beforeDevCommand": "pnpm --filter @mcbot/ui dev",
    "beforeBuildCommand": "cd ../../packages/ui && node node_modules/vite/bin/vite.js build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SteveDeck",
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"]
  }
}
