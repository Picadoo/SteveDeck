{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SteveDeck",
  "version": "0.1.3",
  "identifier": "com.mcbotplayer.app",
  "build": {
    "frontendDist": "../../../packages/ui/dist",
    "devUrl": "http://localhost:5273",
    "beforeDevCommand": "pnpm --filter @mcbot/ui dev",
    "beforeBuildCommand": "cd ../../packages/ui && node node_modules/vite/bin/vite.js build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SteveDeck",
        "width": 1080,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "resources": {
      "../engine-bundle": "engine-bundle"
    },
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDExNkJGNTQ1QTE3MDFFNjgKUldSb0huQ2hSZlZyRWVyYlNkeTdSTFJMMjh0UEp1SFU3R0NldjJvMEZDbHNqUS85REE0YnVVUmcK",
      "endpoints": [
        "https://github.com/Picadoo/SteveDeck/releases/latest/download/latest.json"
      ]
    }
  }
}
