diff --git a/lib/mineflayer.js b/lib/mineflayer.js
index 06634bf6415ec41410e95ec816bebcc239726497..05b537e6a4b2c6758b7137ab7692d197577958de 100644
--- a/lib/mineflayer.js
+++ b/lib/mineflayer.js
@@ -49,6 +49,24 @@ module.exports = (bot, { viewDistance = 6, firstPerson = false, port = 3000, pre
     socket.emit('version', bot.version)
     sockets.push(socket)
 
+    // [mc-bot-player 魔改] 过滤盔甲架：RPG 服大量用隐形盔甲架做全息字/NPC 牌子，
+    // prismarine-viewer 只认原版模型会把它们画乱。实体 spawn 包带 name(类型)，moved/gone 只有 id ——
+    // 丢掉 armor_stand 的 spawn 并记住其 id，连带丢后续 moved/gone（保留真实怪物/玩家）。
+    {
+      const _emit = socket.emit.bind(socket)
+      const hiddenEntityIds = new Set()
+      socket.emit = (ev, data, ...rest) => {
+        if (ev === 'entity' && data && data.id !== 'self') {
+          if (data.name === 'armor_stand') { hiddenEntityIds.add(data.id); return socket }
+          if (hiddenEntityIds.has(data.id)) {
+            if (data.delete) hiddenEntityIds.delete(data.id)
+            return socket
+          }
+        }
+        return _emit(ev, data, ...rest)
+      }
+    }
+
     const worldView = new WorldView(bot.world, viewDistance, bot.entity.position, socket)
     worldView.init(bot.entity.position)
 
@@ -61,12 +79,25 @@ module.exports = (bot, { viewDistance = 6, firstPerson = false, port = 3000, pre
     }
 
     function botPosition () {
-      const packet = { pos: bot.entity.position, yaw: bot.entity.yaw, addMesh: true }
+      const e = bot.entity
       if (firstPerson) {
-        packet.pitch = bot.entity.pitch
+        socket.emit('position', { pos: e.position, yaw: e.yaw, pitch: e.pitch, addMesh: true })
+      } else {
+        // [mc-bot-player 魔改] F5 跟随镜头：相机置于机器人身后上方、随朝向一起转；本体作为独立实体渲染在真实位置。
+        // 原版第三人称只在首帧设一次相机目标、之后不跟随，机器人会走出画面——这里彻底替换为跟随。
+        const dist = 5
+        const lift = 1.5
+        const sin = Math.sin(e.yaw)
+        const cos = Math.cos(e.yaw)
+        // 机器人水平视线方向 (-sin,-cos)，身后即相反方向 (+sin,+cos)
+        const camPos = { x: e.position.x + sin * dist, y: e.position.y + lift, z: e.position.z + cos * dist }
+        // 带 pitch 的位置包 → 客户端走第一人称分支：相机摆到机器人身后上方、略俯视。
+        // 注意：本渲染器 pitch 正值是抬头、负值是低头，所以俯视看机器人要用负值。
+        socket.emit('position', { pos: camPos, yaw: e.yaw, pitch: -0.3, addMesh: false })
+        // 本体用实体通道画在真实位置（玩家模型 + 名牌）
+        socket.emit('entity', { id: 'self', name: 'player', pos: e.position, width: 0.6, height: 1.8, yaw: e.yaw, username: bot.username })
       }
-      socket.emit('position', packet)
-      worldView.updatePosition(bot.entity.position)
+      worldView.updatePosition(e.position)
     }
 
     bot.on('move', botPosition)
